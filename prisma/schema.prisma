generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  avatarUrl     String?
  totalScore    Int      @default(0)
  emailVerified Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  isBanned      Boolean  @default(false)
  tokenVersion  Int      @default(0)
  createdAt     DateTime @default(now())

  sentChallenges             Challenge[]                @relation("Sent")
  receivedChallenges         Challenge[]                @relation("Received")
  guesses                    Guess[]
  reactions                  Reaction[]
  comments                   Comment[]
  friendsInitiated           Friend[]                   @relation("Initiator")
  friendsReceived            Friend[]                   @relation("Receiver")
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  pushSubscriptions          PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friend {
  id          String       @id @default(cuid())
  initiatorId String
  receiverId  String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  initiator User @relation("Initiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver  User @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, receiverId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Challenge {
  id           String    @id @default(cuid())
  senderId     String
  receiverId   String
  photoUrl     String
  fingerCount  Int
  whichFingers String[]
  seen         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  sender    User       @relation("Sent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User       @relation("Received", fields: [receiverId], references: [id], onDelete: Cascade)
  guess     Guess?
  reactions Reaction[]
  comments  Comment[]
}

model Reaction {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  emoji       String
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId, emoji])
}

model Comment {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  text        String
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Guess {
  id                String   @id @default(cuid())
  challengeId       String   @unique
  userId            String
  fingerCountGuess  Int
  whichFingersGuess String[]
  isCountCorrect    Boolean
  isFingersCorrect  Boolean  @default(false)
  points            Int      @default(0)
  createdAt         DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
